#!/bin/bash
#
# SoA-Web watchdog — keeps the PROD daemon (:7332, ~/.soa-web) AND its public
# tunnel alive, so the user never has to ask for a manual restore. Runs every
# 60s via com.soa-web.watchdog.
#
# Covers three failure modes:
#   1. Daemon DOWN  — process gone → restart immediately.
#   2. Daemon HUNG  — alive but unresponsive ~30s (vs merely load-starved, which
#                     it tolerates) → SIGTERM first so the detached tunnel
#                     survives and the restart re-adopts the SAME url; escalate
#                     to kickstart -k only if SIGTERM is ignored.
#   3. Tunnel ZOMBIE — daemon healthy but the cloudflared tunnel lost its edge
#                     connection (process alive, hostname NXDOMAIN). The daemon
#                     only watches for the tunnel PROCESS exiting, so it never
#                     notices. The watchdog re-checks tunnel routing and respawns
#                     it (rate-limited), then texts the new URL via soa-msg.
#
# LOAD-TOLERANT: this host runs many heavy Claude agents (load can exceed 100 on
# 10 cores). A busy daemon is not a dead daemon — never kill one that's merely
# slow, and retry tunnel probes before concluding the tunnel is gone.
#
# SAFETY: only ever touches com.soa-web.server / :7332 / its tunnel. NEVER the
# product instance (:4010 / ~/.soa-web-local). To stop by hand, bootout the
# watchdog FIRST, then the daemon.

set -u

LABEL="com.soa-web.server"
PORT="${SOA_WEB_PORT:-7332}"
UID_="$(id -u)"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
LOCK="$HOME/.soa-web/daemon.lock"
TUNJSON="$HOME/.soa-web/tunnel.json"
LOG="$HOME/.soa-web/logs/watchdog.log"
RESPAWN_MARK="$HOME/.soa-web/logs/.tunnel-respawn"
RESPAWN_MIN_GAP=300   # at most one tunnel respawn / 5 min (avoid URL-churn storms)

mkdir -p "$(dirname "$LOG")" 2>/dev/null

ts()  { date '+%Y-%m-%dT%H:%M:%S'; }
log() { echo "$(ts) $*" >> "$LOG" 2>/dev/null; }
now() { date +%s; }

ping_ok() { curl -fsS --max-time 8 "http://127.0.0.1:${PORT}/api/ping" >/dev/null 2>&1; }

live_owner() {
    local p
    p="$(sed -n 's/.*"pid":[[:space:]]*\([0-9]\{1,\}\).*/\1/p' "$LOCK" 2>/dev/null | head -1)"
    [ -n "$p" ] && kill -0 "$p" 2>/dev/null && echo "$p"
}

tunnel_url() { sed -n 's/.*"url":"\([^"]*\)".*/\1/p' "$TUNJSON" 2>/dev/null | head -1; }
tunnel_pid() { sed -n 's/.*"pid":[[:space:]]*\([0-9]\{1,\}\).*/\1/p' "$TUNJSON" 2>/dev/null | head -1; }

# Detect + recover a zombie tunnel. Only runs when the daemon itself is healthy.
check_tunnel() {
    local url; url="$(tunnel_url)"
    [ -z "$url" ] && return 0                       # no tunnel configured

    # Routing? Retry — under heavy host load DNS/curl flake without the tunnel
    # actually being dead.
    local i
    for i in 1 2 3; do
        curl -fsS --max-time 10 "${url}/api/ping" >/dev/null 2>&1 && return 0
        sleep 3
    done

    # Not routing. Rate-limit respawns so a flapping tunnel doesn't churn URLs
    # every minute.
    local n last; n="$(now)"; last=0
    [ -f "$RESPAWN_MARK" ] && last="$(cat "$RESPAWN_MARK" 2>/dev/null || echo 0)"
    if [ $((n - last)) -lt "$RESPAWN_MIN_GAP" ]; then
        log "tunnel ${url} not routing, but respawned <${RESPAWN_MIN_GAP}s ago — waiting"
        return 0
    fi
    echo "$n" > "$RESPAWN_MARK"

    log "tunnel ${url} not routing (zombie) — respawning cloudflared"
    local oldpid; oldpid="$(tunnel_pid)"
    [ -n "$oldpid" ] && kill "$oldpid" 2>/dev/null

    local cflog="$HOME/.soa-web/logs/cf-respawn.log"
    : > "$cflog"
    nohup cloudflared tunnel --url "http://localhost:${PORT}" >"$cflog" 2>&1 &
    local newpid=$!
    local newurl=""
    for i in $(seq 1 20); do
        # -a: cloudflared writes control bytes to the log, so without it BSD grep
        # reports "Binary file … matches" instead of the URL — that garbage string
        # was landing in tunnel.json and breaking the mobile bridge re-pair.
        newurl="$(grep -aoE 'https://[a-z0-9-]+\.trycloudflare\.com' "$cflog" 2>/dev/null | head -1)"
        [ -n "$newurl" ] && break
        sleep 2
    done

    if [ -n "$newurl" ]; then
        printf '{"provider":"cloudflared","url":"%s","pid":%s,"port":%s,"startedAt":%s}\n' \
            "$newurl" "$newpid" "$PORT" "${n}000" > "$TUNJSON"
        log "tunnel respawned → ${newurl} (pid ${newpid})"
        command -v soa-msg >/dev/null 2>&1 && \
            soa-msg "🔁 Tunnel auto-recovered: https://s0a.app/?backend=${newurl}" >/dev/null 2>&1
    else
        log "tunnel respawn failed to capture URL (host likely overloaded) — retry next cycle"
    fi
}

# ── Daemon health ─────────────────────────────────────────────────────────────
if ping_ok; then
    check_tunnel          # daemon fine — make sure the tunnel is too
    exit 0
fi

PID="$(live_owner)"

if [ -z "$PID" ]; then
    if [ -e "$PLIST" ] && ! launchctl print "gui/${UID_}/${LABEL}" >/dev/null 2>&1; then
        log "daemon down + job not loaded — bootstrap"
        launchctl bootstrap "gui/${UID_}" "$PLIST" >> "$LOG" 2>&1
    else
        log "daemon down (no live lock owner) — kickstart"
        launchctl kickstart "gui/${UID_}/${LABEL}" >> "$LOG" 2>&1
    fi
    sleep 3; log "post-recovery tunnel: $(tunnel_url)"
    exit 0
fi

# Alive but first probe failed — may be load-starved. Re-probe over ~30s.
for _ in 1 2 3 4 5; do
    sleep 5
    if ping_ok; then exit 0; fi
done

log "daemon pid $PID alive but unresponsive ~30s — SIGTERM (preserve tunnel $(tunnel_url))"
kill -TERM "$PID" 2>/dev/null
for _ in 1 2 3 4 5 6 7 8; do sleep 1; kill -0 "$PID" 2>/dev/null || break; done

if kill -0 "$PID" 2>/dev/null; then
    log "pid $PID ignored SIGTERM — kickstart -k (tunnel may churn)"
    launchctl kickstart -k "gui/${UID_}/${LABEL}" >> "$LOG" 2>&1
else
    launchctl kickstart "gui/${UID_}/${LABEL}" >> "$LOG" 2>&1
    log "restarted via SIGTERM+kickstart"
fi
sleep 3; log "post-recovery tunnel: $(tunnel_url)"
exit 0
