#!/bin/bash
#
# SoA-Web watchdog — keeps the PROD daemon (:7332, ~/.soa-web) alive so the user
# never has to ask for a manual restore. Run every 60s by com.soa-web.watchdog.
#
# Design goals (v2):
#   1. LOAD-TOLERANT. The host often runs many heavy Claude agents (load can hit
#      ~100 on 10 cores). A momentarily starved daemon is NOT dead — killing it
#      then churns the tunnel URL and forces a re-pin. So: if the daemon PROCESS
#      is alive but slow, give it a ~30s grace window before doing anything.
#   2. TUNNEL-PRESERVING. Recover a hung daemon with SIGTERM first — the detached
#      cloudflared survives, and the restart re-adopts the SAME public URL (no
#      re-pin). Only escalate to SIGKILL/kickstart -k if it ignores SIGTERM.
#   3. FAST on real death. If the process is GONE, restart immediately.
#
# SAFETY: only ever touches com.soa-web.server / :7332. NEVER the product
# instance (:4010 / ~/.soa-web-local). Never spawns a second daemon. To stop the
# daemon by hand, bootout the watchdog FIRST, then the daemon.

set -u

LABEL="com.soa-web.server"
PORT="${SOA_WEB_PORT:-7332}"
UID_="$(id -u)"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
LOCK="$HOME/.soa-web/daemon.lock"
TUNJSON="$HOME/.soa-web/tunnel.json"
LOG="$HOME/.soa-web/logs/watchdog.log"

mkdir -p "$(dirname "$LOG")" 2>/dev/null

ts()  { date '+%Y-%m-%dT%H:%M:%S'; }
log() { echo "$(ts) $*" >> "$LOG" 2>/dev/null; }

ping_ok() { curl -fsS --max-time 8 "http://127.0.0.1:${PORT}/api/ping" >/dev/null 2>&1; }

# pid that owns the prod state lock, echoed only if that process is actually alive
live_owner() {
    local p
    p="$(sed -n 's/.*"pid":[[:space:]]*\([0-9]\{1,\}\).*/\1/p' "$LOCK" 2>/dev/null | head -1)"
    [ -n "$p" ] && kill -0 "$p" 2>/dev/null && echo "$p"
}

tunnel_url() { sed -n 's/.*"url":"\([^"]*\)".*/\1/p' "$TUNJSON" 2>/dev/null | head -1; }

# Healthy — the common case, costs one fast local request.
if ping_ok; then exit 0; fi

PID="$(live_owner)"

if [ -z "$PID" ]; then
    # No live owner: the daemon is genuinely down. Restart now (no grace window —
    # a dead process won't recover on its own under the current KeepAlive).
    if [ -e "$PLIST" ] && ! launchctl print "gui/${UID_}/${LABEL}" >/dev/null 2>&1; then
        log "daemon down + job not loaded — bootstrap"
        launchctl bootstrap "gui/${UID_}" "$PLIST" >> "$LOG" 2>&1
    else
        log "daemon down (no live lock owner) — kickstart"
        launchctl kickstart "gui/${UID_}/${LABEL}" >> "$LOG" 2>&1
    fi
    sleep 3; log "post-recovery tunnel: $(tunnel_url)"
    exit 0
fi

# Process IS alive but the first probe failed — it may just be load-starved.
# Re-probe over ~30s before concluding it's wedged, so we never kill a daemon
# that is merely busy (which would needlessly churn the tunnel URL).
for _ in 1 2 3 4 5; do
    sleep 5
    if ping_ok; then exit 0; fi
done

# Alive AND unresponsive for ~30s = genuinely hung. SIGTERM first so the detached
# tunnel survives and the restart re-adopts the SAME URL.
log "daemon pid $PID alive but unresponsive ~30s — SIGTERM (preserve tunnel $(tunnel_url))"
kill -TERM "$PID" 2>/dev/null
for _ in 1 2 3 4 5 6 7 8; do sleep 1; kill -0 "$PID" 2>/dev/null || break; done

if kill -0 "$PID" 2>/dev/null; then
    log "pid $PID ignored SIGTERM — kickstart -k (tunnel may churn)"
    launchctl kickstart -k "gui/${UID_}/${LABEL}" >> "$LOG" 2>&1
else
    # Exited cleanly. A conditional KeepAlive won't restart a clean exit, so make
    # sure it comes back; it adopts the surviving tunnel → same URL.
    launchctl kickstart "gui/${UID_}/${LABEL}" >> "$LOG" 2>&1
    log "restarted via SIGTERM+kickstart"
fi
sleep 3; log "post-recovery tunnel: $(tunnel_url)"
exit 0
