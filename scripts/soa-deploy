#!/usr/bin/env bash
#
# soa-deploy — mirror dev repo server code → install dir, restart the LIVE fleet
# daemon, and VERIFY the restart actually took.
#
# Why this exists (the recurring "reload ≠ restart" trap): a browser reload only
# re-fetches the static web/public/** assets — it NEVER restarts the Node daemon.
# So any server/src/** change (a bug fix, a self-heal hardening) stays dormant in
# the already-running process; launchd KeepAlive + the 60s watchdog keep that
# stale process alive (HTTP 200, looks healthy) so it never bounces onto the new
# on-disk code. The fix is an explicit daemon restart — done correctly, with a
# proof that the NEW process is the one now serving. That is exactly this command.
#
# What it does:
#   1. Mirror $DEV_ROOT/server/src/** and $DEV_ROOT/scripts/** → $INSTALL_ROOT
#      (the shared code root for BOTH the :4010 product daemon and the dormant
#      :7332 daemon). rsync -a preserves the +x bit; we re-chmod scripts anyway
#      because a dropped exec bit has bitten us before.
#   2. Restart the live fleet daemon (default :4010 / app.s0a.web.local) via
#      `launchctl kickstart -k`. The graceful SIGTERM flushes tabs + scrollback
#      first; the fresh process boots on the new code, re-adopts the tunnel, and
#      runs boot-reconcile + auto-resume to rehydrate every tab (~1–2 min; each
#      tab lands on a "Resume from summary — Enter to confirm" picker).
#   3. STALENESS CHECK — the whole point: poll until the daemon's pid CHANGES,
#      /api/ping is green, AND the new pid's start time is AFTER the newest
#      mirrored server/src/*.js mtime. That last check is the guarantee the new
#      code is actually running and KeepAlive didn't just keep the stale one.
#   4. Report the recovered tab count.
#
# Static client files (web/public/**) take effect on reload (bump the SW VERSION
# in web/public/m/sw.js) and do NOT need this. Use soa-deploy ONLY for server
# changes.
#
# Usage:
#   soa-deploy                # mirror + restart :4010 + verify (DISRUPTIVE: ~1-2m blip)
#   soa-deploy --dry-run      # show what WOULD mirror + the restart plan; touch nothing
#   soa-deploy --no-restart   # mirror only; activate on the next natural restart
#   soa-deploy --port 7332 --label com.soa-web.server   # target the other daemon
#
# Env overrides: SOA_WEB_DEV_ROOT, SOA_WEB_INSTALL_ROOT, SOA_WEB_PORT.

set -euo pipefail

# ── config / arg parse ────────────────────────────────────────────────────────
DEV_ROOT="${SOA_WEB_DEV_ROOT:-}"
INSTALL_ROOT="${SOA_WEB_INSTALL_ROOT:-$HOME/.soa-web}"
PORT="${SOA_WEB_PORT:-4010}"
LABEL="app.s0a.web.local"
DRY_RUN=0
RESTART=1

while [ $# -gt 0 ]; do
    case "$1" in
        --dry-run)    DRY_RUN=1; shift;;
        --no-restart) RESTART=0; shift;;
        --port)       PORT="$2"; shift 2;;
        --label)      LABEL="$2"; shift 2;;
        --dev-root)   DEV_ROOT="$2"; shift 2;;
        --install-root) INSTALL_ROOT="$2"; shift 2;;
        -h|--help)    sed -n '2,40p' "$0"; exit 0;;
        *) echo "soa-deploy: unknown arg '$1'" >&2; exit 2;;
    esac
done

# Resolve DEV_ROOT: explicit env/flag wins; else the git toplevel of CWD if it
# carries server/src; else the known dev checkout.
if [ -z "$DEV_ROOT" ]; then
    if top="$(git rev-parse --show-toplevel 2>/dev/null)" && [ -d "$top/server/src" ]; then
        DEV_ROOT="$top"
    else
        DEV_ROOT="$HOME/Desktop/Hireal/soa-web"
    fi
fi

[ -d "$DEV_ROOT/server/src" ] || { echo "soa-deploy: no server/src under DEV_ROOT=$DEV_ROOT" >&2; exit 1; }
[ -d "$INSTALL_ROOT" ]        || { echo "soa-deploy: INSTALL_ROOT does not exist: $INSTALL_ROOT" >&2; exit 1; }

echo "soa-deploy: DEV_ROOT=$DEV_ROOT"
echo "soa-deploy: INSTALL_ROOT=$INSTALL_ROOT"
echo "soa-deploy: target daemon = $LABEL (:$PORT)"
echo

ping_ok() { curl -fsS --max-time 8 -H 'ngrok-skip-browser-warning: 1' "http://127.0.0.1:${PORT}/api/ping" >/dev/null 2>&1; }
daemon_pid() { launchctl print "gui/$(id -u)/${LABEL}" 2>/dev/null | awk -F'= ' '/^[[:space:]]*pid =/{print $2; exit}'; }
tab_count() {
    curl -fsS --max-time 8 -H 'ngrok-skip-browser-warning: 1' "http://127.0.0.1:${PORT}/api/manager" 2>/dev/null \
      | python3 -c 'import sys,json;d=json.load(sys.stdin);print(len(d.get("tabs",d.get("sessions",[]))))' 2>/dev/null || echo "?"
}
# epoch of a process start time (macOS `ps -o lstart`), 0 on failure.
pid_start_epoch() {
    local pid="$1" s
    s="$(ps -o lstart= -p "$pid" 2>/dev/null | tr -s ' ')" || return 0
    [ -n "$s" ] || { echo 0; return 0; }
    date -j -f "%a %b %d %T %Y" "$s" +%s 2>/dev/null || echo 0
}
# newest mtime among the mirrored server/src js files, epoch.
newest_src_mtime() {
    local newest=0 m
    for f in "$INSTALL_ROOT"/server/src/*.js; do
        [ -f "$f" ] || continue
        m="$(stat -f %m "$f" 2>/dev/null || echo 0)"
        [ "$m" -gt "$newest" ] && newest="$m"
    done
    echo "$newest"
}

# ── 1. mirror ─────────────────────────────────────────────────────────────────
OLD_PID="$(daemon_pid || true)"
echo "current $LABEL pid: ${OLD_PID:-<none>}"

if [ "$DRY_RUN" = 1 ]; then
    echo
    echo "── DRY RUN: files that would change (server/src + scripts) ──"
    rsync -an --itemize-changes "$DEV_ROOT/server/src/" "$INSTALL_ROOT/server/src/" | sed 's/^/  src   /'
    rsync -an --itemize-changes "$DEV_ROOT/scripts/"    "$INSTALL_ROOT/scripts/"    | sed 's/^/  bin   /'
    echo
    echo "would then: launchctl kickstart -k gui/$(id -u)/${LABEL}"
    echo "would verify: pid changes from ${OLD_PID:-<none>}, /api/ping green, new start ≥ newest src mtime"
    echo "(dry run — nothing mirrored, daemon untouched)"
    exit 0
fi

echo "mirroring server/src + scripts → $INSTALL_ROOT …"
rsync -a "$DEV_ROOT/server/src/" "$INSTALL_ROOT/server/src/"
rsync -a "$DEV_ROOT/scripts/"    "$INSTALL_ROOT/scripts/"
chmod +x "$INSTALL_ROOT"/scripts/* 2>/dev/null || true
echo "mirror done."

if [ "$RESTART" = 0 ]; then
    echo
    echo "soa-deploy: --no-restart → code mirrored but the daemon is STILL running"
    echo "the old code. It will activate on the next daemon restart. (reload ≠ restart!)"
    exit 0
fi

# ── 2. restart the live daemon ────────────────────────────────────────────────
echo
echo "restarting $LABEL (graceful SIGTERM flushes tabs+scrollback, then reboots on new code)…"
launchctl kickstart -k "gui/$(id -u)/${LABEL}"

# ── 3. staleness check ────────────────────────────────────────────────────────
NEWEST="$(newest_src_mtime)"
echo "newest mirrored server/src mtime: $(date -r "$NEWEST" '+%H:%M:%S' 2>/dev/null || echo "$NEWEST")"
echo "waiting for the NEW process to come up and prove it's on the new code…"

ok=0
for i in $(seq 1 40); do
    sleep 1
    NEW_PID="$(daemon_pid || true)"
    [ -n "$NEW_PID" ] || continue
    [ "$NEW_PID" != "${OLD_PID:-}" ] || continue   # must be a fresh process
    ping_ok || continue
    START="$(pid_start_epoch "$NEW_PID")"
    if [ "${START:-0}" -ge "$NEWEST" ]; then
        ok=1
        echo "✓ new pid $NEW_PID up, /api/ping green, started $(date -r "$START" '+%H:%M:%S') ≥ code mtime — NOT stale"
        break
    else
        echo "  pid $NEW_PID up but started before newest code mtime — still waiting (t=${i}s)"
    fi
done

if [ "$ok" != 1 ]; then
    echo "✗ soa-deploy: could not confirm a fresh, non-stale daemon within 40s." >&2
    echo "  check: launchctl print gui/$(id -u)/${LABEL}  +  $INSTALL_ROOT/logs/" >&2
    exit 1
fi

# ── 4. report ─────────────────────────────────────────────────────────────────
echo
echo "fleet tabs now live: $(tab_count)"
echo "soa-deploy: done. Restored tabs will sit on the 'Resume from summary' picker —"
echo "send Enter to each (POST /api/tabs/:id/keys {\"text\":\"\\r\"}) or just open the app."
