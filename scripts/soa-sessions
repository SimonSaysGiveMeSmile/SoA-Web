#!/usr/bin/env node
/**
 * soa-sessions — let a *manager agent* see and drive every other SoA session.
 *
 * SoA runs many terminals (tabs), each often a Claude Code agent. This CLI gives
 * a dedicated manager agent (its own tab, its own context) full oversight of the
 * fleet: read each session's status + context %, read its recent output, send it
 * input, or compact it. Pair it with the dashboard's always-on supervisor.
 *
 * Usage:
 *   soa-sessions list                     # all sessions: status, context %, signals
 *   soa-sessions read <id> [lines]        # recent output of a session (default 80)
 *   soa-sessions send <id> <text...>      # type text + Enter into a session
 *   soa-sessions say  <id> <text...>      # type text WITHOUT Enter
 *   soa-sessions compact <id>             # run /compact in a session
 *
 * Endpoint discovery: SOA_WEB_TTS_URL (injected into SoA shells) → bridge.json →
 * default port. Loopback only.
 */

const http = require('http');
const fs = require('fs');
const os = require('os');
const path = require('path');

function base() {
    if (process.env.SOA_WEB_TTS_URL) return process.env.SOA_WEB_TTS_URL.replace(/\/api\/tts$/, '');
    try {
        const j = JSON.parse(fs.readFileSync(path.join(os.homedir(), '.soa-web', 'bridge.json'), 'utf8'));
        if (j && j.port) return 'http://127.0.0.1:' + j.port;
    } catch (_) {}
    return 'http://127.0.0.1:' + (process.env.SOA_WEB_PORT || '7332');
}

function post(body, opts = {}) {
    return new Promise((resolve, reject) => {
        const data = JSON.stringify(body);
        const u = new URL(base() + '/api/sessions');
        const headers = { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) };
        // Positive proof of local origin (per-daemon secret injected into our tab's
        // env) so the loopback gate trusts us even behind a local reverse proxy.
        if (process.env.SOA_WEB_LOCAL_KEY) headers['x-soa-local-key'] = process.env.SOA_WEB_LOCAL_KEY;
        const req = http.request({
            hostname: u.hostname, port: u.port, path: u.pathname, method: 'POST',
            headers,
        }, (res) => {
            let b = ''; res.on('data', d => b += d);
            res.on('end', () => { try { resolve(JSON.parse(b)); } catch (_) { resolve({ ok: false, raw: b }); } });
        });
        req.on('error', reject);
        // `watch` is a long-poll; hold the socket open past the server's
        // heartbeat cap so we aren't cut off client-side mid-wait.
        if (opts.timeoutMs) req.setTimeout(opts.timeoutMs, () => req.destroy(new Error('client timeout')));
        req.write(data); req.end();
    });
}

// ── Manager-agent helpers ────────────────────────────────────────────────────
// The caller's own tab id (env-injected into every SoA shell). Forwarded as
// `self` so a manager hides its own events and is excluded from cohort fan-outs.
const SELF = process.env.SOA_WEB_TAB ? Number(process.env.SOA_WEB_TAB) : undefined;

function argval(flag) { const i = process.argv.indexOf(flag); return i !== -1 ? process.argv[i + 1] : undefined; }
function hasFlag(flag) { return process.argv.includes(flag); }
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// Target selector: a number, a comma-list of numbers, or a cohort name.
function cohort(arg) {
    if (arg == null) return undefined;
    if (/^\d+$/.test(arg)) return Number(arg);
    if (/^\d+(,\d+)+$/.test(arg)) return arg.split(',').map(Number);
    // all | working | attention | stuck | idle | done | highContext | limited
    // | group:<name>  (a user-defined static group; resolved server-side)
    return arg;
}

function stateDir() { return process.env.SOA_WEB_STATE_DIR || path.join(os.homedir(), '.soa-web'); }
function cursorPath() {
    const tab = process.env.SOA_WEB_TAB ? '-' + process.env.SOA_WEB_TAB : '';
    return path.join(stateDir(), '.soa-mgr-cursor' + tab);
}
function readCursor() { try { const v = Number(fs.readFileSync(cursorPath(), 'utf8').trim()); return Number.isFinite(v) ? v : null; } catch (_) { return null; } }
function writeCursor(v) { try { fs.mkdirSync(path.dirname(cursorPath()), { recursive: true }); fs.writeFileSync(cursorPath(), String(v)); } catch (_) {} }

// One human-readable line per event: `[ev 142] #3 "api" attention (was working) ctx 41%`
function renderEvent(e) {
    const parts = [`[ev ${e.seq}]`, `#${e.id}`];
    if (e.title) parts.push(`"${e.title}"`);
    parts.push(e.kind);
    if (e.from && e.to) parts.push(`(was ${e.from})`);
    if (e.ctxPct != null) parts.push(`ctx ${e.ctxPct}%`);
    if (e.detail) parts.push(`— ${e.detail}`);
    return parts.join(' ');
}

function fmtList(snap) {
    if (!snap.sessions || !snap.sessions.length) return '(no sessions)';
    const c = snap.counts || {};
    const head = `${c.total} sessions · ${c.working || 0} working · ${c.attention || 0} need input · ${c.stuck || 0} stuck · ${c.idle || 0} idle · ${c.highContext || 0} high-context · ${c.limited || 0} limited`;
    const hhmm = ms => { const d = new Date(ms); return d.getHours() + ':' + String(d.getMinutes()).padStart(2, '0'); };
    const rows = snap.sessions.map(s => {
        const flags = [
            s.attention ? 'NEEDS-INPUT' : '',
            s.stuck ? 'STUCK' : '',
            s.highContext ? 'HIGH-CTX' : '',
            s.limited ? `LIMITED→${s.limitResetAt ? hhmm(s.limitResetAt) : '?'}` : '',
            s.resumeAt ? `RESUME@${hhmm(s.resumeAt)}` : '',
        ].filter(Boolean).join(' ');
        const ctx = s.ctxPct != null ? s.ctxPct + '%' : '—';
        return `  #${s.id}  ${(s.title || '').padEnd(20).slice(0, 20)}  ${String(s.status).padEnd(9)}  ctx ${ctx.padStart(4)}  ${flags}`;
    });
    return head + '\n' + rows.join('\n');
}

(async () => {
    const [cmd, ...rest] = process.argv.slice(2);
    try {
        if (!cmd || cmd === 'list' || cmd === 'ls') {
            const r = await post({ action: 'list' });
            console.log(r.ok ? fmtList(r) : JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        if (cmd === 'read') {
            const r = await post({ action: 'read', id: Number(rest[0]), lines: rest[1] ? Number(rest[1]) : undefined });
            if (r.ok) { console.log(`# session #${r.id} "${r.title}" · ${r.status} · ctx ${r.ctxPct ?? '—'}%\n`); console.log(r.text || '(empty)'); }
            else console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        if (cmd === 'send' || cmd === 'say') {
            const id = Number(rest[0]);
            const text = rest.slice(1).join(' ');
            const r = await post({ action: 'send', id, text, submit: cmd === 'send' });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        if (cmd === 'compact') {
            const r = await post({ action: 'compact', id: Number(rest[0]) });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // group <id> [name]   — assign an agent to a group (empty name → revert
        // to its auto project group). Groups are targetable as `group:<name>`.
        if (cmd === 'group') {
            const r = await post({ action: 'setGroup', id: Number(rest[0]), group: rest.slice(1).join(' ') });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // schedule <id|all|limited> <epochMs|+15m|2:30am> [text…]   (text defaults to "continue")
        if (cmd === 'schedule') {
            const id = (rest[0] === 'all' || rest[0] === 'limited') ? rest[0] : Number(rest[0]);
            const at = /^\d{10,}$/.test(rest[1] || '') ? Number(rest[1]) : rest[1];
            const r = await post({ action: 'schedule', id, at, text: rest.slice(2).join(' ') || 'continue', self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // resume-all [when] [text…] — nudge every limit-hit session (default: 2 min from now)
        if (cmd === 'resume-all') {
            const at = rest[0] || '+2m';
            const r = await post({ action: 'schedule', id: 'limited', at, text: rest.slice(1).join(' ') || 'continue', self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        if (cmd === 'schedules') {
            const r = await post({ action: 'schedules' });
            console.log(JSON.stringify(r, null, 2));
            process.exit(r.ok ? 0 : 1);
        }
        if (cmd === 'unschedule') {
            const r = await post({ action: 'unschedule', scheduleId: rest[0] });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // config [autoResume on|off] [text <resume text…>]
        if (cmd === 'config') {
            const body = { action: 'config' };
            if (rest[0] === 'autoResume') body.autoResume = rest[1] === 'on' || rest[1] === 'true';
            if (rest[0] === 'text') body.autoResumeText = rest.slice(1).join(' ');
            const r = await post(body);
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // ── Manager-agent verbs ──────────────────────────────────────────────
        // whoami — confirm the manager's own tab id/title/status + head cursor.
        if (cmd === 'whoami') {
            const r = await post({ action: 'whoami', self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // events — non-blocking drain (startup reconciliation before watch).
        if (cmd === 'events') {
            const since = argval('--since') != null ? Number(argval('--since')) : undefined;
            const kinds = argval('--kinds') ? argval('--kinds').split(',').map(s => s.trim()).filter(Boolean) : undefined;
            const r = await post({ action: 'events', since, kinds, self: SELF });
            if (r.ok) {
                (r.events || []).forEach(e => console.log(renderEvent(e)));
                if (!r.events || !r.events.length) console.log('(no events)');
                if (r.dropped) console.log(`  … ${r.dropped} earlier event(s) dropped — run \`soa-sessions list\` to reconcile`);
            } else console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // watch — BLOCKING long-poll loop. React, don't poll: this blocks inside
        // the HTTP request between events (≈0 CPU). Persists its cursor so a
        // re-run resumes where it left off. --once: block until events then exit.
        if (cmd === 'watch') {
            const kindsArg = argval('--kinds');
            const kinds = kindsArg ? kindsArg.split(',').map(s => s.trim()).filter(Boolean) : undefined;
            const timeoutS = Number(argval('--timeout')) || 25;
            const once = hasFlag('--once');
            const raw = hasFlag('--raw');
            let cursor = hasFlag('--catchup') ? 0 : readCursor();
            let lastSeq = -1;
            let lastEpoch = null;
            for (;;) {
                let r;
                try {
                    r = await post(
                        { action: 'watch', cursor, kinds, timeoutMs: timeoutS * 1000, self: SELF },
                        { timeoutMs: (timeoutS + 30) * 1000 },
                    );
                } catch (_) { await sleep(1000); continue; }   // daemon bounce → retry
                if (!r || !r.ok) { await sleep(1000); continue; }
                // A daemon restart resets the server's _seq to 0. Our stale cursor
                // (from the dead epoch) would make the SERVER filter out low-seq
                // post-restart events (e.seq <= cursor), and our in-memory lastSeq
                // would swallow the rest. The server stamps a per-boot `epoch` on
                // every reply; the instant it changes, re-read the NEW epoch from
                // seq 0 and re-accept from scratch. This fully closes the restart
                // event-loss — including the "busy restart" case where the new _seq
                // already climbed past our cursor (so cursor>head never triggers).
                if (r.epoch && lastEpoch !== null && r.epoch !== lastEpoch) {
                    lastEpoch = r.epoch; lastSeq = -1; cursor = 0; writeCursor(0);
                    console.log('  … daemon restarted — reconcile via `soa-sessions list`');
                    continue; // re-poll immediately from the start of the new epoch
                }
                if (lastEpoch === null) lastEpoch = r.epoch;   // first reply: adopt epoch, keep cursor
                if (typeof r.cursor === 'number') { cursor = r.cursor; writeCursor(cursor); }
                const evs = r.events || [];
                for (const e of evs) {
                    // The synthetic daemon-restart marker is a user-visible reconcile hint.
                    if (e.kind === 'daemon-restart') { lastSeq = -1; console.log(renderEvent(e)); continue; }
                    // Dedup on the server's unique monotonic seq — NOT (id,kind),
                    // which would collapse a genuinely-new second 'attention' from
                    // the same tab (the intervening transition is filtered out by
                    // --kinds and never seen here). seq guards only re-delivery.
                    if (!raw && e.seq <= lastSeq) continue;
                    lastSeq = e.seq;
                    console.log(renderEvent(e));
                }
                if (r.dropped) console.log(`  … ${r.dropped} earlier event(s) dropped — run \`soa-sessions list\` to reconcile`);
                // --once = exactly one *completed* long-poll cycle then exit
                // (events OR a heartbeat). The instant no-cursor priming reply
                // (timedOut:false, no events) doesn't count — loop once more so
                // a fresh watcher actually waits for the next event.
                if (once && (evs.length || r.timedOut)) break;
            }
            process.exit(0);
        }
        // goal / btw — fan a per-session goal (or aside) to one tab or a cohort.
        if (cmd === 'goal' || cmd === 'btw') {
            const id = cohort(rest[0]);
            const text = rest.slice(1).join(' ');
            const r = await post({ action: 'goal', verb: cmd, id, text, self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // clear — send /clear to a tab or cohort.
        if (cmd === 'clear') {
            const r = await post({ action: 'goal', verb: 'clear', id: cohort(rest[0]), self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // resume — type 'claude --resume <id> || claude --continue' into tab(s).
        if (cmd === 'resume') {
            const r = await post({ action: 'goal', verb: 'resume', id: cohort(rest[0]), self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // broadcast — fleet-wide plain-text nudge to a cohort.
        if (cmd === 'broadcast' || cmd === 'bcast') {
            const to = cohort(rest[0]);
            const text = rest.slice(1).join(' ');
            const r = await post({ action: 'broadcast', to, text, self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // spawn — open a new tab + start/resume a Claude agent in it.
        if (cmd === 'spawn') {
            const flagsWithVal = new Set(['--title', '--goal', '--model']);
            const positional = [];
            for (let i = 0; i < rest.length; i++) {
                const a = rest[i];
                if (a.startsWith('--')) { if (flagsWithVal.has(a)) i++; continue; }
                positional.push(a);
            }
            const r = await post({
                action: 'spawn',
                cwd: positional[0],
                title: argval('--title'),
                resume: !hasFlag('--no-resume'),
                claude: !hasFlag('--no-claude'),
                goal: argval('--goal'),
                model: argval('--model'),
            });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // stop — kill a tab/agent (refuses your own tab).
        if (cmd === 'stop') {
            const r = await post({ action: 'stop', id: Number(rest[0]), self: SELF });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        // interrupt — send Ctrl-C (no Enter) to unwedge a stuck agent.
        if (cmd === 'interrupt') {
            const r = await post({ action: 'interrupt', id: Number(rest[0]) });
            console.log(JSON.stringify(r));
            process.exit(r.ok ? 0 : 1);
        }
        console.error('usage: soa-sessions list | read <id> [lines] | send <id> <text> | say <id> <text> | compact <id>\n' +
                      '       schedule <id|all|limited> <+15m|2:30am|epochMs> [text] | resume-all [when] [text]\n' +
                      '       schedules | unschedule <scheduleId> | config autoResume on|off | config text <text>\n' +
                      '   manager-agent:\n' +
                      '       whoami | events [--since N] [--kinds a,b] | watch [--kinds a,b] [--timeout 25] [--once] [--catchup] [--raw]\n' +
                      '       goal <id|all|attention|stuck|idle|done|highContext|limited> <text> | btw <id|cohort> <note> | clear <id|cohort>\n' +
                      '       resume <id|all|limited> | broadcast <all|working|attention|idle|limited> <text>\n' +
                      '       spawn [<cwd>] [--title T] [--no-resume] [--no-claude] [--goal "..."] [--model m] | stop <id> | interrupt <id>');
        process.exit(1);
    } catch (e) {
        console.error('soa-sessions error:', e.message, '(is the SoA server running?)');
        process.exit(1);
    }
})();
