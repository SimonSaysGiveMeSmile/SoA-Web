#!/bin/bash
#
# soa-manager-watchdog — keeps the manager agent alive so the fleet self-sustains
# indefinitely. Run every 90s via com.soa-web.manager-watchdog launchd job.
#
# The manager agent is a dedicated SoA tab whose job is to watch all other sessions
# via `soa-sessions watch/goal/resume` and keep them productive. Without a watchdog
# the manager itself is the single point of failure: if it exits (context limit,
# usage limit, crash) the whole fleet goes unsupervised.
#
# This script closes that gap:
#   1. HEALTHY  — manager tab is working/idle/attention — do nothing.
#   2. STUCK    — manager silent >4m → interrupt + resume in-place.
#   3. LIMITED  — hit usage limit → resume in-place (claude --continue).
#   4. HIGH-CTX — context ≥ 80% → /compact so it doesn't run out mid-shift.
#   5. MISSING  — tab gone (exited, crashed, never spawned) → spawn fresh manager.
#
# Manager identity: stored in $SOA_WEB_STATE_DIR/manager-id (written on first
# spawn). Falls back to scanning for a tab titled "manager" if the ID is stale.
#
# Instance-parameterized via env (defaults to the legacy :7332/~.soa-web):
#   SOA_WEB_PORT       daemon health port  (default 7332)
#   SOA_WEB_STATE_DIR  logs + identity     (default ~/.soa-web)
# soa-sessions reaches the daemon via its own bridge.json / SOA_WEB_TTS_URL.

set -euo pipefail

STATE_DIR="${SOA_WEB_STATE_DIR:-$HOME/.soa-web}"
LOG="$STATE_DIR/logs/manager-watchdog.log"
ID_FILE="$STATE_DIR/manager-id"
PORT="${SOA_WEB_PORT:-7332}"

# The manager's standing mandate: fully own running the fleet so the user doesn't
# have to (open / modify / pause / resume any agent, at any time). Closing tabs is
# OFF by default — the manager never reaps inactive tabs unless the user opts in
# (soa-sessions config closeInactive on).
MANAGER_GOAL="You are the fleet manager — you fully own running the fleet so the user does not have to. Run the event loop: soa-sessions whoami, then events+list to reconcile, then forever block on: soa-sessions watch — for each event, read the offending session and act. You may OPEN (spawn), MODIFY (goal/btw), and PAUSE (interrupt) any agent at any time to keep the fleet unblocked and productive. Do NOT close inactive tabs: an idle or done agent is fine left alone — never 'stop' it. Tab-closing is disabled by default (closeInactive=off); only close a tab if the user has explicitly enabled it, and even then prefer interrupt+resume over stop unless an agent is truly dead. You are equipped with the full skill toolbox — use it yourself or hand it to agents you spawn: frontend-design (polished UI/frontend work), computeruse (drive macOS apps, screenshot + OCR/read on-screen UI), browseruse (control Chrome / Browser Use for web tasks and logins), deep-research (multi-source cited research), code-review and simplify (review/clean a diff), verify and run (launch the app and confirm a change works), slides (decks), vercel (deploy), gsd (structured planning). When a session's task calls for one of these, invoke the skill or spawn/goal an agent equipped for it. HEARTBEAT (core duty, every ~15 min — also on a launchd timer via soa-heartbeat): sweep EVERY tab (active, idle, AND dead) for blockers — needs-input, stuck, API errors, usage limits, high context, exited — and confirm each agent is still following its project's PRD/goal objectives; unblock routine prompts with safe defaults, redirect agents that have drifted off their PRD, resume dead ones, and escalate only genuine decisions. As part of each heartbeat, use your browser skills (soa-browser, which streams into the SoA BROWSER panel; or browseruse/computeruse) to MIMIC A REAL USER — visit each product's live webpage, click through its key flows, and screenshot — so you catch UI/UX and deploy regressions the agents can't see from the terminal. Never command your own tab id. Only soa-msg the user when a decision is genuinely theirs."

mkdir -p "$(dirname "$LOG")" 2>/dev/null

ts()  { date '+%Y-%m-%dT%H:%M:%S'; }
log() { echo "$(ts) $*" >> "$LOG" 2>/dev/null; }

# ── Daemon must be up first ────────────────────────────────────────────────────
if ! curl -fsS --max-time 5 "http://127.0.0.1:${PORT}/api/ping" >/dev/null 2>&1; then
    log "daemon not responding on :${PORT} — skipping (soa-watchdog handles daemon restart)"
    exit 0
fi

# ── Premium gate ────────────────────────────────────────────────────────────────
# The Fleet Manager is a paid feature. On a free/unlicensed install, don't spawn
# or supervise a manager tab at all. Ask the daemon what THIS install is entitled
# to; only proceed when manager is enabled. (Fails open only if the probe itself
# errors, so a transient hiccup doesn't strand a paying user's manager.)
CAPS="$(curl -fsS --max-time 5 "http://127.0.0.1:${PORT}/api/capabilities" 2>/dev/null || echo '')"
if [ -n "$CAPS" ] && ! printf '%s' "$CAPS" | grep -q '"manager":[[:space:]]*true'; then
    log "manager feature not entitled for this install — skipping (free tier)"
    exit 0
fi

# ── Snapshot live sessions ─────────────────────────────────────────────────────
SESSION_LIST="$(soa-sessions list 2>/dev/null || true)"

# ── Parse `soa-sessions list` lines ───────────────────────────────────────────
# Line format (title is padded to 20 chars and MAY CONTAIN SPACES):
#   "  #<id>  <title>  <status>  ctx <pct>  [FLAGS…]"
#   '  #1  Master Chef           working    ctx  14%  '
#   '  #7  api                   attention  ctx  41%  NEEDS-INPUT'
# Positional field parsing (awk $3/$5) broke on multi-word titles: "Master Chef"
# shifted every column, logging garbage like "status=Chef ctx=ctx%". Instead we
# anchor on the TRAILING columns — the status word immediately before the last
# "ctx <pct>" — and treat everything after the pct as flags (NEEDS-INPUT /
# STUCK / HIGH-CTX / LIMITED→HH:MM). ctx prints "—" when unknown → tab_ctx
# yields empty and callers default to 0.
TAIL_RE='[[:space:]]([^[:space:]]+)[[:space:]]+ctx[[:space:]]+([0-9]+%|—)[[:space:]]*(.*)$'

tab_line()   { echo "$SESSION_LIST" | grep -E "^[[:space:]]*#${1}[[:space:]]" | head -1 || true; }
tab_status() { tab_line "$1" | sed -nE "s/^.*${TAIL_RE}/\1/p"; }
tab_ctx()    { tab_line "$1" | sed -nE "s/^.*${TAIL_RE}/\2/p" | sed -nE 's/^([0-9]+)%$/\1/p'; }
tab_flags()  { tab_line "$1" | sed -nE "s/^.*${TAIL_RE}/\3/p" | sed -E 's/[[:space:]]+$//'; }

tab_exists() {
    local id="$1"
    echo "$SESSION_LIST" | grep -q "^[[:space:]]*#${id}[[:space:]]"
}

# Find a tab by title; print its id or nothing.
find_by_title() {
    local title="$1" live="" any="" line id rest status
    # Prefer a LIVE (non-done) manager tab; fall back to any manager tab.
    # Picking the lowest-id tab blindly used to select a stale "done" duplicate,
    # which then re-triggered the done→respawn path (manager proliferation).
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*\#([0-9]+)[[:space:]][[:space:]](.*)$ ]]; then
            id="${BASH_REMATCH[1]}"
            rest="${BASH_REMATCH[2]}"
            # Exact-title match against the padded title field: the title must be
            # followed by a padding space ("manager" must NOT match "manager-ui").
            if [[ "$rest" == "$title "* || "$rest" == "$title" ]]; then
                status="$(tab_status "$id")"
                if [ "$status" != "done" ] && [ -z "$live" ]; then live="$id"; fi
                if [ -z "$any" ]; then any="$id"; fi
            fi
        fi
    done <<< "$SESSION_LIST"
    echo "${live:-$any}"
}

spawn_manager() {
    local result
    # --no-resume: a manager is spawned only when NONE is live, so start FRESH.
    # Resuming the "latest" session in this cwd grabbed a stale cross-instance
    # manager transcript (referenced a retired fleet's tab ids) — start clean and
    # let the event loop re-baseline from soa-sessions whoami/list.
    result="$(soa-sessions spawn --no-resume --title manager --goal "$MANAGER_GOAL" 2>&1 || true)"
    log "spawn result: $result"
    local new_id=""
    if [[ "$result" =~ \"id\":([0-9]+) ]]; then
        new_id="${BASH_REMATCH[1]}"
    elif [[ "$result" =~ tab[[:space:]]#([0-9]+) ]]; then
        new_id="${BASH_REMATCH[1]}"
    fi
    if [ -n "$new_id" ]; then
        echo "$new_id" > "$ID_FILE"
        log "manager spawned as tab #$new_id"
        command -v soa-msg >/dev/null 2>&1 && \
            soa-msg "Manager agent spawned (tab #$new_id) — fleet is now self-supervised." 2>/dev/null || true
    else
        log "spawn succeeded but couldn't parse tab ID from output"
    fi
}

# ── Identify manager tab ───────────────────────────────────────────────────────
MGR_ID=""

if [ -f "$ID_FILE" ]; then
    stored="$(cat "$ID_FILE" 2>/dev/null | tr -d '[:space:]')"
    if [ -n "$stored" ] && tab_exists "$stored"; then
        MGR_ID="$stored"
    else
        log "stored manager-id '$stored' not in live sessions — scanning by title"
    fi
fi

if [ -z "$MGR_ID" ]; then
    MGR_ID="$(find_by_title manager)"
    if [ -n "$MGR_ID" ]; then
        log "found manager tab by title: #$MGR_ID"
        echo "$MGR_ID" > "$ID_FILE"
    fi
fi

# ── Spawn if not found ────────────────────────────────────────────────────────
if [ -z "$MGR_ID" ]; then
    log "no manager tab found — spawning fresh"
    spawn_manager
    exit 0
fi

# ── Manager tab found — evaluate state ────────────────────────────────────────
STATUS="$(tab_status "$MGR_ID")"
CTX_PCT="$(tab_ctx "$MGR_ID")"
FLAGS="$(tab_flags "$MGR_ID")"
log "manager tab #$MGR_ID — status=${STATUS:-?} ctx=${CTX_PCT:-0}% flags='${FLAGS:-}'"

case "${STATUS:-}" in
    working|idle|attention)
        rm -f "$STATE_DIR/.manager-done-count"   # alive — clear any done streak
        if [ "${CTX_PCT:-0}" -ge 80 ] || echo "$FLAGS" | grep -q "HIGH-CTX"; then
            log "manager #$MGR_ID ctx=${CTX_PCT}% HIGH — compacting"
            soa-sessions compact "$MGR_ID" 2>/dev/null || true
        fi
        ;;
    limited)
        log "manager #$MGR_ID hit usage limit — resuming in-place"
        soa-sessions resume "$MGR_ID" 2>/dev/null || true
        command -v soa-msg >/dev/null 2>&1 && \
            soa-msg "Manager (tab #$MGR_ID) resumed after usage limit." 2>/dev/null || true
        ;;
    done)
        # A manager that just finished a turn briefly shows "done" but is STILL
        # ALIVE — its /goal Stop hook revives the event loop. Respawning on a
        # single transient "done" caused new manager tabs to pile up every turn
        # boundary. Only respawn if "done" PERSISTS across consecutive checks
        # (~3 runs ≈ 4.5m); a truly-exited tab is caught by the MISSING path above.
        DONE_FILE="$STATE_DIR/.manager-done-count"
        prev_done="$(cat "$DONE_FILE" 2>/dev/null | tr -d '[:space:]')"
        cur_done=$(( ${prev_done:-0} + 1 ))
        if [ "$cur_done" -ge 3 ]; then
            log "manager #$MGR_ID 'done' persisted ${cur_done}x — treating as exited, respawning"
            rm -f "$ID_FILE" "$DONE_FILE"
            spawn_manager
        else
            echo "$cur_done" > "$DONE_FILE"
            log "manager #$MGR_ID transient 'done' (${cur_done}/3) — alive, not respawning"
        fi
        ;;
    "")
        log "manager #$MGR_ID returned empty status — skipping"
        ;;
    *)
        if echo "$FLAGS" | grep -q "STUCK" || [ "$STATUS" = "stuck" ]; then
            log "manager #$MGR_ID STUCK — interrupt + resume"
            soa-sessions interrupt "$MGR_ID" 2>/dev/null || true
            sleep 2
            soa-sessions resume "$MGR_ID" 2>/dev/null || true
        else
            log "manager #$MGR_ID status='$STATUS' — no action"
        fi
        ;;
esac

exit 0
