# SOA_WEB_HOST=127.0.0.1
# SOA_WEB_PORT=7332

# AUTH — pick one.
# 'shared' requires SOA_WEB_PASSWORD.
# 'none' trusts an upstream proxy (Cloudflare Access, tailscale funnel, oauth2_proxy).
# 'open' is localhost-only; server refuses to start on non-loopback hosts.
SOA_WEB_AUTH=shared
SOA_WEB_PASSWORD=change-me

# HMAC key for the auth cookie. Set this in prod so restarts don't log users out.
# Any random string >=16 chars.
# SOA_WEB_SIGN_KEY=

# Uncomment when you terminate HTTPS in front of this server.
# SOA_WEB_SECURE_COOKIE=1

# Shell binary (defaults to $SHELL or /bin/bash).
# SOA_WEB_SHELL=/bin/zsh

# Idle session timeout, ms. Default 6h.
# SOA_WEB_SESSION_TTL_MS=21600000

# Cloudflare Quick Tunnel on boot (default on). Set 0 to disable — e.g. when
# fronted by a named tunnel, nginx+TLS, or another upstream proxy.
# SOA_WEB_AUTOPAIR=0

# Per-tab scrollback replayed on WS reconnect. Default 256 KiB.
# SOA_WEB_SCROLLBACK_BYTES=262144

# Cross-origin deploy (Vercel SPA + tunneled backend). Comma-separated list
# of origins that may call /api/* and open /ws. When set, cookies are issued
# with SameSite=None; Secure so they survive cross-site requests.
# SOA_WEB_ALLOWED_ORIGINS=https://your-app.vercel.app
