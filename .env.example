# SOA_WEB_HOST=127.0.0.1
# SOA_WEB_PORT=7332

# AUTH — pick one.
# 'shared' requires SOA_WEB_PASSWORD.
# 'none' trusts an upstream proxy (Cloudflare Access, tailscale funnel, oauth2_proxy).
# 'open' is localhost-only; server refuses to start on non-loopback hosts.
SOA_WEB_AUTH=shared
SOA_WEB_PASSWORD=change-me

# HMAC key for the auth cookie. Set this in prod so restarts don't log users out.
# Any random string >=16 chars.
# SOA_WEB_SIGN_KEY=

# Uncomment when you terminate HTTPS in front of this server.
# SOA_WEB_SECURE_COOKIE=1

# Shell binary (defaults to $SHELL or /bin/bash).
# SOA_WEB_SHELL=/bin/zsh

# Idle session timeout, ms. Default 6h.
# SOA_WEB_SESSION_TTL_MS=21600000
